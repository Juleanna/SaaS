# ============================================================
# Django — обов'язкові в продакшені
# ============================================================
# Генерація: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# ============================================================
# База даних
# ============================================================
DB_NAME=saas_platform
DB_USER=postgres
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432

# ============================================================
# Redis / Celery
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# ============================================================
# Суперюзер при першому старті (опційно, тільки dev)
# ============================================================
CREATE_SUPERUSER=false
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=

# ============================================================
# Міграції — тільки для backend-сервісу
# ============================================================
RUN_MIGRATIONS=true

# ============================================================
# Email (опційно)
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# ============================================================
# Sentry (опційно)
# ============================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================
# S3 / MinIO для media (опційно — якщо не задано, працює локальне сховище)
# ============================================================
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-central-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# ============================================================
# Платіжні системи (опційно)
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# ============================================================
# Telegram / Instagram (опційно)
# ============================================================
TELEGRAM_BOT_TOKEN=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ============================================================
# Rate limiting
# ============================================================
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10
